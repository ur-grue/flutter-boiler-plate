# Copy to ~/.appfactory/secrets.env and fill ONCE. Never commit. chmod 600.
# Client-safe (public SDK keys) — go into dart_define:
REVENUECAT_API_KEY=""           # RevenueCat public SDK key
ADS_ENABLED="false"
ADMOB_APP_ID_ANDROID=""
ADMOB_APP_ID_IOS=""
API_BASE_URL="https://example.com"

# Backend (Supabase) — URL/anon are client-safe; service key stays server-side:
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_PROJECT_REF=""

# Server-side only (used to deploy the LLM-proxy edge function, never shipped in app):
LLM_API_KEY=""                  # OpenAI/Anthropic key for the edge function

# Store / signing (used by /release + fastlane later):
APPLE_TEAM_ID=""
ASC_KEY_ID=""
ASC_ISSUER_ID=""

# Optional: plug a real ASO data source here (else web_search + aso-optimizer skill):
ASO_DATA_SOURCE=""

# Optional — aso-skills live App Store data (https://appeeky.com). Author-time only; NOT shipped in the app.
# Keyless by default (general ASO frameworks); this key only unlocks live App Store data.
# Never goes into dart_define / never bundled into the build.
APPEEKY_API_KEY=""
