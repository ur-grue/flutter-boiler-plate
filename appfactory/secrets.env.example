# Copy to ~/.appfactory/secrets.env and fill ONCE. Never commit. chmod 600.
# Client-safe (public SDK keys) — go into dart_define:
REVENUECAT_API_KEY=""           # RevenueCat public SDK key
ADS_ENABLED="false"
ADMOB_APP_ID_ANDROID=""
ADMOB_APP_ID_IOS=""
API_BASE_URL="https://example.com"

# Backend (Supabase) — URL/anon are client-safe; service key stays server-side:
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_PROJECT_REF=""

# Server-side only (used to deploy the LLM-proxy edge function, never shipped in app):
LLM_API_KEY=""                  # OpenAI/Anthropic key for the edge function

# Store / signing (used by /release + fastlane). Author-time only; never shipped in the app.
# These turn the last mile into one command (./ship.sh → fastlane) — no typing in App Store
# Connect / Play Console. Fill ONCE; leave blank to just build + generate assets locally.
APPLE_TEAM_ID=""                 # Apple Developer Team ID (Membership page)
# App Store Connect API key (App Store Connect ▸ Users and Access ▸ Integrations ▸ Keys):
ASC_KEY_ID=""                    # Key ID
ASC_ISSUER_ID=""                 # Issuer ID
ASC_KEY_PATH=""                  # path to the downloaded AuthKey_XXXX.p8 (kept OUTSIDE the repo)
# Google Play Developer API (service-account JSON from Play Console ▸ API access):
PLAY_JSON_KEY_PATH=""            # path to the service-account .json (kept OUTSIDE the repo)
# fastlane match (code signing) — a PRIVATE git repo that stores certs/profiles (recommended):
MATCH_GIT_URL=""                 # e.g. git@github.com:you/certificates.git

# Optional: plug a real ASO data source here (else web_search + aso-optimizer skill):
ASO_DATA_SOURCE=""

# Optional — aso-skills live App Store data (https://appeeky.com). Author-time only; NOT shipped in the app.
# Keyless by default (general ASO frameworks); this key only unlocks live App Store data.
# Never goes into dart_define / never bundled into the build.
APPEEKY_API_KEY=""
